<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiBiller.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:config="clr-namespace:MauiBiller.Configuration"
    x:DataType="config:AppConfiguration"
    Title="MauiBiller">

    <Shell.FlyoutHeader>
        <Grid
            Padding="24,48,24,20"
            RowDefinitions="Auto,Auto,Auto">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="MauiBiller" />
            <Label
                Grid.Row="1"
                Margin="0,6,0,0"
                Text="{Binding EnvironmentName, StringFormat='Environment: {0}'}" />
            <Label
                Grid.Row="2"
                Margin="0,2,0,0"
                Text="{Binding Firebase.ProjectId, StringFormat='Firebase project: {0}'}" />
        </Grid>
    </Shell.FlyoutHeader>

</Shell>
