<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiBiller.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:MauiBiller.Pages.Authentication"
    xmlns:billing="clr-namespace:MauiBiller.Pages.Billing"
    xmlns:clients="clr-namespace:MauiBiller.Pages.Clients"
    xmlns:config="clr-namespace:MauiBiller.Configuration"
    xmlns:projects="clr-namespace:MauiBiller.Pages.Projects"
    xmlns:settings="clr-namespace:MauiBiller.Pages.Settings"
    xmlns:timeTracking="clr-namespace:MauiBiller.Pages.TimeTracking"
    x:DataType="config:AppConfiguration"
    Title="MauiBiller">

    <Shell.FlyoutHeader>
        <Grid
            Padding="24,48,24,20"
            RowDefinitions="Auto,Auto,Auto">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="MauiBiller" />
            <Label
                Grid.Row="1"
                Margin="0,6,0,0"
                Text="{Binding EnvironmentName, StringFormat='Environment: {0}'}" />
            <Label
                Grid.Row="2"
                Margin="0,2,0,0"
                Text="{Binding Firebase.ProjectId, StringFormat='Firebase project: {0}'}" />
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate auth:LoginPage}"
        Route="login" />

    <ShellContent
        Title="Clients"
        ContentTemplate="{DataTemplate clients:ClientsPage}"
        Route="clients" />

    <ShellContent
        Title="Projects"
        ContentTemplate="{DataTemplate projects:ProjectsPage}"
        Route="projects" />

    <ShellContent
        Title="Timer"
        ContentTemplate="{DataTemplate timeTracking:TimerPage}"
        Route="timer" />

    <ShellContent
        Title="Billing"
        ContentTemplate="{DataTemplate billing:BillingPage}"
        Route="billing" />

    <ShellContent
        Title="Settings"
        ContentTemplate="{DataTemplate settings:SettingsPage}"
        Route="settings" />

</Shell>
